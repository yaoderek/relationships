# Optional — only needed for AI features (day summaries, semantic analysis).
# Everything else works without this. Get a key at https://platform.openai.com/api-keys
# Copy this file to .env and paste your key:
OPENAI_API_KEY=insert_openai_key_here

# Optional: override the chat model used for day summaries.
# OPENAI_MODEL=gpt-5-nano
